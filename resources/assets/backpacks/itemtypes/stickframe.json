{
  "code": "backbag",
  "class": "Item",
  "tags": ["backpack", "slot-backpacks-backpack"],
  "variantgroups": [{ "code": "category", "states": ["back"] }, { "code": "subtype", "states": ["plain"] }, { "code": "type", "states": ["stickframe"] }],
  "shape": { "base": "attachable/{type}" },
  "texturesByType": { "*": { "seraph": { "base": "game:block/transparent" } } },
  "storageFlags": 128,
  "behaviors": [
    {
      "name": "PlayerInventoryLib:EnableSlotsBehavior",
      "properties": {
        "slotsToEnable": ["backpacks:backpack-accessory-0", "backpacks:backpack-accessory-1"],
        "configOverride": { "*": { "OverrideTags": true, "Tags": ["stickframe-accessory"], "Icon": "backpacks:backpack" } }
      }
    },
    {
      "name": "AttributeRenderingLibrary.Wearable",
      "properties": {
        "textures": {
          "rope-flaxtwine::wood-*": { "backframe-strap": { "base": "game:block/cloth/linen/plain" }, "backframe-material": { "base": "game:block/wood/debarked/{wood}" } },
          "rope-reedrope::wood-*": { "backframe-strap": { "base": "game:item/resource/rope" }, "backframe-material": { "base": "game:block/wood/debarked/{wood}" } },
          "rope-*::wood-*": { "backframe-strap": { "base": "game:block/cloth/{rope}" }, "backframe-material": { "base": "game:block/wood/debarked/{wood}" } },
          "*": { "backframe-strap": { "base": "game:block/cloth/reedrope" }, "backframe-material": { "base": "game:block/wood/debarked/oak" } }
        }
      }
    },
    {
      "name": "Backpacks:ShapeReplacement",
      "properties": {
        "renderTargets": ["Gui", "HandTp", "HandTpOff", "Ground"],
        "shape": { "*": { "base": "backpacks:gui/stickframe" } },
        "textures": {
          "rope-flaxtwine::wood-*": { "backframe-strap": { "base": "game:block/cloth/linen/plain" }, "backframe-material": { "base": "game:block/wood/debarked/{wood}" } },
          "rope-reedrope::wood-*": { "backframe-strap": { "base": "game:item/resource/rope" }, "backframe-material": { "base": "game:block/wood/debarked/{wood}" } },
          "rope-*::wood-*": { "backframe-strap": { "base": "game:block/cloth/{rope}" }, "backframe-material": { "base": "game:block/wood/debarked/{wood}" } },
          "*": { "backframe-strap": { "base": "game:block/cloth/reedrope" }, "backframe-material": { "base": "game:block/wood/debarked/oak" } }
        }
      }
    },
    {
      "name": "AttributeRenderingLibrary.GenerateCreativeStacks",
      "properties": { "variantgroups": [{ "code": "rope", "states": ["reedrope", "flaxtwine"] }, { "code": "wood", "states": ["oak"] }], "creativeinventory": { "backpacks-colors": ["*"] } }
    }
  ],
  "attributes": { "wearableAttachment": true, "handbook": { "groupBy": ["*"] } },
  "creativeinventory": { "general": ["*"], "backpacks": ["*"] },
  "creativeinventoryStacks": [{ "tabs": ["general", "backpacks-colors"], "stacks": [{ "type": "item", "code": "backbag-{category}-{subtype}-{type}" }] }],
  "renderAlphaTest": "0.25",
  "tpHandTransform": { "translation": { "x": 0, "y": "-0.05", "z": 0 }, "rotation": { "x": 0, "y": 180, "z": 48 }, "origin": { "x": 0, "y": 0, "z": 0 }, "scale": 1 },
  "guiTransform": { "translation": { "x": 0, "y": 0, "z": 0 }, "rotation": { "x": 161, "y": -134, "z": 0 }, "origin": { "x": "-0.02", "y": "0.2", "z": 0 }, "scaleXyz": { "x": "-2.54", "y": "2.54", "z": "2.54" } },
  "groundTransform": { "translation": { "x": 0, "y": 0, "z": 0 }, "rotation": { "x": 90, "y": 0, "z": 0 }, "origin": { "x": 0, "y": 0, "z": "0.1" }, "scale": 4 }
}

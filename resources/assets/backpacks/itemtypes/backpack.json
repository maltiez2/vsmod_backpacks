{
  "code": "backbag",
  "class": "Item",
  "tags": ["backpack", "slot-backpacks-backpack"],
  "variantgroups": [{ "code": "category", "states": ["back"] }, { "code": "subtype", "states": ["plain"] }, { "code": "type", "states": ["backpack"] }],
  "shape": { "base": "attachable/{type}" },
  "texturesByType": { "*": { "seraph": { "base": "game:block/transparent" } } },
  "storageFlags": 128,
  "behaviors": [
    { "name": "PlayerInventoryLib:BackpackBehavior", "properties": { "slotGroups": { "backpack": { "number": 18 } } } },
    {
      "name": "PlayerInventoryLib:EnableSlotsBehavior",
      "properties": {
        "slotsToEnable": ["backpacks:backpack-accessory-0", "backpacks:backpack-accessory-1", "backpacks:backpack-accessory-2"],
        "configOverride": { "*": { "OverrideTags": true, "Tags": ["backpack-accessory"], "Icon": "backpacks:backpack" } }
      }
    },
    {
      "name": "AttributeRenderingLibrary.Wearable",
      "properties": {
        "textures": {
          "metal-*::leather-*::straps-leather-*": {
            "backpack-material-1": { "base": "game:block/leather/{leather}" },
            "backpack-material-2": { "base": "game:block/leather/{straps-leather}" },
            "backpack-metal": { "base": "game:block/metal/plate/{metal}" }
          }
        }
      }
    },
    {
      "name": "Backpacks:ShapeReplacement",
      "properties": {
        "renderTargets": ["Gui", "HandTp", "HandTpOff", "Ground"],
        "shape": { "*": { "base": "backpacks:gui/backpack" } },
        "textures": {
          "metal-*::leather-*::straps-leather-*": {
            "backpack-material-1": { "base": "game:block/leather/{leather}" },
            "backpack-material-2": { "base": "game:block/leather/{straps-leather}" },
            "backpack-metal": { "base": "game:block/metal/plate/{metal}" }
          }
        }
      }
    },
    {
      "name": "AttributeRenderingLibrary.GenerateCreativeStacks",
      "properties": {
        "variantgroups": [
          { "code": "metal", "states": ["brass", "copper", "tinbronze", "bismuthbronze", "blackbronze", "gold", "silver", "iron", "meteoriciron", "steel"] },
          { "code": "leather", "states": ["plain", "orange", "black", "red", "blue", "purple", "pink", "white", "yellow", "gray", "green"] },
          { "code": "straps-leather", "states": ["plain", "orange", "black", "red", "blue", "purple", "pink", "white", "yellow", "gray", "green"] }
        ],
        "creativeinventory": { "backpacks-colors": ["*"] }
      }
    }
  ],
  "attributes": { "wearableAttachment": true, "handbook": { "groupBy": ["*"] } },
  "creativeinventory": { "general": ["*"], "backpacks": ["*"] },
  "creativeinventoryStacks": [{ "tabs": ["general", "backpacks-colors"], "stacks": [{ "type": "item", "code": "backbag-{category}-{subtype}-{type}" }] }],
  "renderAlphaTest": "0.25",
  "tpHandTransform": { "translation": { "x": 0, "y": "-0.05", "z": 0 }, "rotation": { "x": 0, "y": 180, "z": 48 }, "origin": { "x": 0, "y": 0, "z": 0 }, "scale": 1 },
  "guiTransform": { "translation": { "x": 0, "y": 0, "z": 0 }, "rotation": { "x": 161, "y": -134, "z": 0 }, "origin": { "x": "-0.02", "y": "0.2", "z": 0 }, "scaleXyz": { "x": "-2.98", "y": "2.98", "z": "2.98" } },
  "groundTransform": { "translation": { "x": 0, "y": 0, "z": 0 }, "rotation": { "x": 90, "y": 0, "z": 0 }, "origin": { "x": 0, "y": 0, "z": "0.1" }, "scale": 4 }
}
